__pycache__/
*.pyc
smc_radar.log
*.tmp
logs/
phase2_scan_log.jsonl
.claude/settings.local.json
# Ignore cache CONTENTS (not the dir itself) so the !exceptions below can
# re-include specific files — a negation cannot un-ignore a file whose parent
# DIRECTORY is excluded, so we must glob the contents instead.
backtest/cache/*
# Exception: the 6 swept pairs' H1 bars ARE committed so the CI knob-sweep
# runner (a fresh clone with no local MT5 cache) can load data. H1-only, ~17MB
# total — small, and the ONLY data path the sweep uses. Everything else under
# backtest/cache/ stays ignored.
!backtest/cache/EURUSD_X_1h.parquet
!backtest/cache/JPY_X_1h.parquet
!backtest/cache/NZDUSD_X_1h.parquet
!backtest/cache/CHF_X_1h.parquet
!backtest/cache/NQ_F_1h.parquet
!backtest/cache/GC_F_1h.parquet
backtest/results/
backtest/mt5_data/
backtest/mt5_login.txt*
backtest/yfinance_archive/
dr_old_tmp.py
state/archives/
.claude/scheduled_tasks.lock
backtest/logs/
backtest/state/
debug/

# Backtest scan-log working files. The run zips these to *.jsonl.gz.zip (the
# committed audit trail); the loose .jsonl are intermediate scratch that churns
# every run and must never be hand-committed. The .gz.zip is NOT matched here.
backtest/out/scanlog/**/*.jsonl
